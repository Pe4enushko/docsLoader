WEAVIATE_URL=http://localhost:8080

OLLAMA_EMBED_BASE_URL=http://localhost:11434
OLLAMA_CHAT_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=paraphrase-multilingual:latest
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_CHAT_NUM_CTX=32768

INGEST_CHECKPOINT_FILE=.graphrag_ingest_checkpoint.json

MANIFEST_PATH=manifest.csv
CONTEXT_TARGET=10

ONE_C_APPOINTMENTS_URL=<ONE_C_APPOINTMENTS_URL>
ONE_C_LOGIN=<ONE_C_LOGIN>
ONE_C_PASSWORD=<ONE_C_PASSWORD>
ONE_C_TIMEOUT_SECONDS=15

POSTGRES_HOST=<POSTGRES_HOST>
POSTGRES_PORT=5432
POSTGRES_USER=<POSTGRES_USER>
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=<POSTGRES_DB>
POSTGRES_SSLMODE=prefer

SCORES_SYSTEM_PROMPT=Ты ассистент внутреннего контроля качества заполнения медицинского приёма в российской клинике. Используй только предоставленные фрагменты клинических рекомендаций и входной JSON визита. Не используй внешние медицинские знания.
